# ============================================================
# Revenant — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------ Cognee Cloud ------
# Your tenant URL from the Cognee Cloud dashboard
COGNEE_CLOUD_BASE=https://tenant-<your-id>.aws.cognee.ai

# Your Cognee API key (starts with ck_...)
COGNEE_API_KEY=ck_...

# ------ Anthropic ------
# Your Anthropic API key for Claude claude-sonnet-4-5
ANTHROPIC_API_KEY=sk-ant-...

# ------ Frontend (Next.js) ------
# URL of the running FastAPI backend
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL for live graph events
NEXT_PUBLIC_WS_URL=ws://localhost:8000
