<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://revenant.game/ontology#trustImpact">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#ActionEvent"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:label>trustImpact</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#secretHolder">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#SecretFact"/>
    <rdfs:range rdf:resource="http://revenant.game/ontology#NPC"/>
    <rdfs:label>secretHolder</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#actionPerformed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#ActionEvent"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>actionPerformed</rdfs:label>
    <rdfs:comment>The specific action: betray, steal, help, pay, insult, compliment, bribe.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#discoveryQuery">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#SecretFact"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>discoveryQuery</rdfs:label>
    <rdfs:comment>The natural language query that reveals this secret via graph traversal.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#targetNPC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#Rumor"/>
    <rdfs:range rdf:resource="http://revenant.game/ontology#NPC"/>
    <rdfs:label>targetNPC</rdfs:label>
    <rdfs:comment>The NPC that received and now holds this rumor in memory.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#validUntil">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#TrustEdge"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    <rdfs:label>validUntil</rdfs:label>
    <rdfs:comment>Timestamp when this trust state was superseded. Open interval if still current.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#trustScore">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#TrustEdge"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:label>trustScore</rdfs:label>
    <rdfs:comment>Current trust score 0-100.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#documentId">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#InteractionEvent"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>documentId</rdfs:label>
    <rdfs:comment>Cognee document_id for surgical forget() targeting.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#sourceNPC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#Rumor"/>
    <rdfs:range rdf:resource="http://revenant.game/ontology#NPC"/>
    <rdfs:label>sourceNPC</rdfs:label>
    <rdfs:comment>The NPC that originated or propagated this rumor.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#gameDay">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#TrustEdge"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#InteractionEvent"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:label>gameDay</rdfs:label>
    <rdfs:comment>Game day on which this trust change occurred.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#rumorBehavior">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#NPC"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>rumorBehavior</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#propagationType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#Rumor"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>propagationType</rdfs:label>
    <rdfs:comment>How the rumor was spread (direct_warning, overheard, improve_pipeline).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#eventType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#InteractionEvent"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>eventType</rdfs:label>
    <rdfs:comment>Type of event: qa, skill_run, feedback, trace.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#participant">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#InteractionEvent"/>
    <rdfs:range rdf:resource="http://revenant.game/ontology#NPC"/>
    <rdfs:label>participant</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#SecretFact">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>SecretFact</rdfs:label>
    <rdfs:comment>Hidden information discoverable via multi-hop graph traversal.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#secretContent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#SecretFact"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>secretContent</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#Rumor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Rumor</rdfs:label>
    <rdfs:comment>Unverified information propagated between NPCs via the improve() pipeline.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#role">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#NPC"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>role</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#NPC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>NPC</rdfs:label>
    <rdfs:comment>A non-player character with persistent memory and social relationships.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#validFrom">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#TrustEdge"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    <rdfs:label>validFrom</rdfs:label>
    <rdfs:comment>Timestamp when this trust state became valid (transaction time).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#trustDelta">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#TrustEdge"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:label>trustDelta</rdfs:label>
    <rdfs:comment>Signed change in trust score that created this state.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#InteractionEvent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>InteractionEvent</rdfs:label>
    <rdfs:comment>A recorded interaction between the Player and an NPC.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#personality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#NPC"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>personality</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#Player">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Player</rdfs:label>
    <rdfs:comment>The human player interacting with the game world.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#TrustEdge">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>TrustEdge</rdfs:label>
    <rdfs:comment>A bi-temporal trust relationship from an NPC toward the Player.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#ActionEvent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>ActionEvent</rdfs:label>
    <rdfs:comment>A player action (betray, steal, help, pay) recorded as feedback memory.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#propagatedAt">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#Rumor"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    <rdfs:label>propagatedAt</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#rumorContent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#Rumor"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>rumorContent</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#npcId">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#NPC"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>npcId</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://revenant.game/ontology#trustEvent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://revenant.game/ontology#TrustEdge"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>trustEvent</rdfs:label>
    <rdfs:comment>Human-readable event that caused trust change (e.g. betrayal, payment, rumor).</rdfs:comment>
  </rdf:Description>
</rdf:RDF>
